# OpenRouter API 키 (필수). https://openrouter.ai/keys 에서 발급.
OPENROUTER_API_KEY=sk-or-...

# 드라이버가 캐릭터를 띄울 워크스페이스 경로 (선택, 기본값=드라이버 실행 cwd).
# 이 경로가 픽셀 오피스 서버의 워크스페이스와 다르면 오피스 설정에서
# "Watch All Sessions" 를 켜야 캐릭터가 채택됩니다.
# PIXEL_WORKSPACE=C:\aistudy\pixelAgent_hanjaejin\pixel-agents

# 에이전트 행동 루프 1회 주기(ms). 비용/레이트리밋 조절용 (선택, 기본 4000, 최소 1000).
# PIXEL_LOOP_INTERVAL_MS=4000

# OpenRouter 동시 호출 상한 (선택, 기본 2). 낮출수록 비용/429 위험 감소.
# PIXEL_MAX_CONCURRENCY=2

# LLM 호출 실패 시 지수 백오프 (선택). base 부터 2배씩 늘어 max 에서 멈춤.
# PIXEL_BACKOFF_BASE_MS=2000
# PIXEL_BACKOFF_MAX_MS=30000
